<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CfaDatabaseEditor.ViewModels"
        xmlns:m="using:CfaDatabaseEditor.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="700"
        x:Class="CfaDatabaseEditor.Views.EnSyncWindow"
        x:DataType="vm:EnSyncViewModel"
        Title="EN Database Sync"
        Width="1300" Height="750"
        MinWidth="900" MinHeight="550">

    <DockPanel Margin="8">
        <!-- URL Input -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="Paste the URL of the expansion page to sync:" FontWeight="Bold"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Scrape" Margin="4,0,0,0"
                        Command="{Binding ScrapeCommand}"/>
                <Button DockPanel.Dock="Right" Content="Stop" Margin="4,0,0,0"
                        Command="{Binding StopCommand}"/>
                <TextBox Text="{Binding Url}"
                         Watermark="https://en.cf-vanguard.com/cardlist/cardsearch/?expansion=248"/>
            </DockPanel>
            <DockPanel>
                <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" Background="{DynamicResource EncodingIssueBrush}" BorderBrush="Red" BorderThickness="1" CornerRadius="2" VerticalAlignment="Center"/>
                    <TextBlock Text="= encoding issue" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0"
                    HorizontalAlignment="Right">
            <Button Content="Approve Selected" Click="OnApproveSelectedClick"/>
            <Button Content="Approve All Above 75%" Command="{Binding ApproveAboveThresholdCommand}"/>
            <Separator Width="1" Margin="4,0"/>
            <Button Content="Apply Approved" Command="{Binding ApplySelectedCommand}" FontWeight="Bold"/>
            <Button Content="Close" Click="OnCloseClick"/>
        </StackPanel>

        <!-- Main content: table + preview -->
        <Grid ColumnDefinitions="*,Auto,320">

            <!-- LEFT: Match Results Table -->
            <DataGrid Grid.Column="0"
                      x:Name="ResultsGrid"
                      ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedResult}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Extended"
                      x:CompileBindings="False">
                <DataGrid.Columns>
                    <!-- EN Name: display normally, double-click row then F2 to edit -->
                    <DataGridTextColumn Header="EN Name" Binding="{Binding EnName}" Width="220" IsReadOnly="False"/>

                    <!-- Encoding warning -->
                    <DataGridTemplateColumn Header="!" Width="30">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="m:SyncResult" x:CompileBindings="False">
                                <TextBlock Text="&#9888;" Foreground="Red" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           IsVisible="{Binding HasEncodingIssue}"
                                           ToolTip.Tip="{Binding EncodingIssueDetails}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Card No" Binding="{Binding EnCardNo}" Width="160" IsReadOnly="True"/>
                    <DataGridTextColumn Header="CFA Match" Binding="{Binding MatchedCard.CardName}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="CFA ID" Binding="{Binding MatchedCardStat}" Width="88" IsReadOnly="False"/>
                    <DataGridTextColumn Header="Conf. %" Binding="{Binding Confidence, StringFormat=\{0:F1\}}" Width="96" IsReadOnly="True"/>

                    <!-- Approve: clickable checkbox without entering edit mode -->
                    <DataGridTemplateColumn Header="Appr." Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="m:SyncResult" x:CompileBindings="False">
                                <CheckBox IsChecked="{Binding IsApproved, Mode=TwoWay}"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Done: read-only checkbox -->
                    <DataGridTemplateColumn Header="Done" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="m:SyncResult" x:CompileBindings="False">
                                <CheckBox IsChecked="{Binding IsApplied}" IsEnabled="False"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"/>

            <!-- RIGHT: Image Comparison -->
            <Border Grid.Column="2" Background="{DynamicResource InfoPanelBackgroundBrush}" CornerRadius="4" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Image Comparison" FontWeight="Bold"
                               FontSize="13" Margin="0,0,0,8"/>

                    <!-- Selected card info -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource InfoBoxBackgroundBrush}" CornerRadius="4" Padding="6" Margin="0,0,0,8"
                            IsVisible="{Binding SelectedResult, Converter={x:Static ObjectConverters.IsNotNull}}"
                            x:CompileBindings="False">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding SelectedResult.EnName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource SubtleTextBrush}">
                                <Run Text="Matched to CFA #"/>
                                <Run Text="{Binding SelectedResult.MatchedCard.CardStat}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding SelectedResult.Confidence, StringFormat=\{0:F1\}%}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Side-by-side images -->
                    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,8,*">
                        <!-- Labels -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="EN (Downloaded)"
                                   FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="CFA (Current)"
                                   FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>

                        <!-- EN Image -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#333" CornerRadius="4">
                            <Image Source="{Binding EnPreviewImage}"
                                   Stretch="Uniform" StretchDirection="DownOnly"/>
                        </Border>

                        <!-- CFA Image -->
                        <Border Grid.Row="1" Grid.Column="2" Background="#333" CornerRadius="4">
                            <Image Source="{Binding CfaPreviewImage}"
                                   Stretch="Uniform" StretchDirection="DownOnly"/>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
