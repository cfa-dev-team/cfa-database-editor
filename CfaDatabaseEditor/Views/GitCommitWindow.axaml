<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CfaDatabaseEditor.Views.GitCommitWindow"
        Title="Commit / Discard"
        Width="600" Height="520"
        MinWidth="450" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">
        <!-- Bottom: buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="StageAllButton" Content="Stage All" Click="OnStageAllClick" Width="90"/>
            <Button x:Name="UnstageAllButton" Content="Unstage All" Click="OnUnstageAllClick" Width="90"/>
            <Button x:Name="DiscardButton" Content="Discard Selected" Click="OnDiscardClick" Width="120" IsEnabled="False"
                    Foreground="#C62828"/>
            <Button x:Name="CommitButton" Content="Commit" Click="OnCommitClick" Width="90" IsEnabled="False"/>
            <Button Content="Close" Click="OnCloseClick" Width="80"/>
        </StackPanel>

        <!-- Commit message -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Top" Text="Commit Message:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="CommitMessageBox" AcceptsReturn="True" TextWrapping="Wrap"
                     Height="80" Watermark="Enter commit message..."
                     TextChanged="OnCommitMessageChanged"/>
        </DockPanel>

        <!-- Status -->
        <TextBlock x:Name="StatusLabel" DockPanel.Dock="Bottom" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"
                   Margin="0,4,0,0" TextWrapping="Wrap"/>

        <!-- File list -->
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Changed Files:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Border BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1" CornerRadius="4">
                <ScrollViewer>
                    <StackPanel x:Name="FileListPanel" Spacing="2" Margin="4"/>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </DockPanel>
</Window>
