<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CfaDatabaseEditor.Views.GitDiffWindow"
        Title="Diff"
        Width="1100" Height="700"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock x:Name="HeaderLabel" Text="" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Width="80" Click="OnCloseClick" IsCancel="True"/>
        </StackPanel>

        <TextBlock x:Name="StatusLabel" DockPanel.Dock="Bottom" FontSize="11"
                   Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>

        <Border BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <ScrollViewer x:Name="TextScroller" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="DiffGrid" ColumnDefinitions="42,*,42,*"/>
                </ScrollViewer>
                <Grid x:Name="ImagePanel" IsVisible="False" ColumnDefinitions="*,*">
                    <Border Grid.Column="0" Background="#202020" Padding="8" Margin="0,0,2,0">
                        <DockPanel>
                            <TextBlock x:Name="LeftImageLabel" DockPanel.Dock="Top"
                                       Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <Image x:Name="LeftImage" Stretch="Uniform"/>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#202020" Padding="8" Margin="2,0,0,0">
                        <DockPanel>
                            <TextBlock x:Name="RightImageLabel" DockPanel.Dock="Top"
                                       Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <Image x:Name="RightImage" Stretch="Uniform"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </DockPanel>
</Window>
