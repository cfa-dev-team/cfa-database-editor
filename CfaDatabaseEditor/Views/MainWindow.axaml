<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CfaDatabaseEditor.ViewModels"
        xmlns:m="using:CfaDatabaseEditor.Models"
        xmlns:conv="using:CfaDatabaseEditor.Converters"
        xmlns:ctrl="using:CfaDatabaseEditor.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        x:Class="CfaDatabaseEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CFA Database Editor v1.2.0 beta"
        Icon="avares://CfaDatabaseEditor/Assets/CFADBE.ico"
        Width="1400" Height="850"
        MinWidth="900" MinHeight="600">

    <Window.Resources>
        <conv:NationIdToColorConverter x:Key="NationColorConv"/>
        <conv:NullableIntToStringConverter x:Key="NullIntConv"/>
        <conv:PathToBitmapConverter x:Key="PathToBitmap"/>
        <conv:CardToColorBrushConverter x:Key="CardColorConv"/>
    </Window.Resources>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem x:Name="OpenMenuItem" Header="_Open Database..." Click="OnOpenDatabaseClick"
                          InputGesture="Ctrl+O"/>
                <MenuItem x:Name="RecentMenu" Header="_Recent Folders"
                          SubmenuOpened="OnRecentMenuOpened">
                    <MenuItem Header="(empty)" IsEnabled="False"/>
                </MenuItem>
                <MenuItem Header="_Reload Database" Click="OnReloadDatabaseClick"
                          InputGesture="Ctrl+R"/>
                <MenuItem x:Name="SaveMenuItem" Header="_Save All"
                          Command="{Binding SaveCommand}"
                          InputGesture="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Card">
                <MenuItem x:Name="NewCardMenu" Header="_New Card">
                    <MenuItem Header="Cray Elemental (NoClan)" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.CrayElemental}"/>
                    <MenuItem Header="Order Cards" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.OrderFilter}"/>
                    <Separator/>
                    <MenuItem Header="Dragon Empire" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.DragonEmpire}"/>
                    <MenuItem Header="Dark States" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.DarkStates}"/>
                    <MenuItem Header="Keter Sanctuary" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.KeterSanctuary}"/>
                    <MenuItem Header="Stoicheia" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.Stoicheia}"/>
                    <MenuItem Header="Brandt Gate" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.BrandtGate}"/>
                    <MenuItem Header="Lyrical Monasterio" Command="{Binding AddNewCardCommand}" CommandParameter="{x:Static m:ClanRegistry.LyricalMonasterio}"/>
                </MenuItem>
                <MenuItem x:Name="DuplicateMenuItem" Header="_Duplicate" Command="{Binding DuplicateCardCommand}"
                          InputGesture="Ctrl+D"/>
            </MenuItem>
            <MenuItem Header="_Git" x:Name="GitMenu" IsVisible="{Binding IsGitRepo}">
                <MenuItem Header="_Fetch" Click="OnGitFetchClick"/>
                <MenuItem Header="P_ull" Click="OnGitPullClick"/>
                <MenuItem Header="_Push" Click="OnGitPushClick"/>
                <Separator/>
                <MenuItem Header="_Commit / Discard..." Click="OnGitCommitClick"/>
                <MenuItem Header="Checkout _Branch..." Click="OnGitCheckoutClick"/>
                <Separator/>
                <MenuItem Header="_Refresh Status" Click="OnGitRefreshClick"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Built-in Factions..." Click="OnBuiltInFactionsClick"/>
                <MenuItem Header="Custom _Factions..." Click="OnCustomFactionsClick"/>
                <Separator/>
                <MenuItem Header="EN Database _Sync..." Click="OnEnSyncClick"/>
                <MenuItem Header="_JP Card Archive..." Click="OnJpArchiveClick"/>
            </MenuItem>
            <MenuItem Header="_Deploy">
                <MenuItem Header="_Deploy" Click="OnDeployClick"
                          IsEnabled="{Binding IsLoaded}"/>
                <MenuItem Header="_Choose Local CFA..." Click="OnChooseLocalCfaClick"/>
                <Separator/>
                <MenuItem Header="_Update Old Sprites" ToggleType="CheckBox"
                          IsChecked="{Binding UpdateOldSprites, Mode=TwoWay}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Reset Layout" Click="OnResetLayoutClick"/>
                <Separator/>
                <MenuItem Header="_About" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="8,4">
            <DockPanel>
                <!-- Git branch indicator (right side, VS Code style) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding IsGitRepo}" Margin="12,0,0,0">
                    <TextBlock Text="{Binding GitBranchDisplay}"
                               Foreground="{Binding GitBranchColor}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Cursor="Hand"
                               PointerPressed="OnGitBranchClick"/>
                </StackPanel>
                <!-- Status text (left side) -->
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid x:Name="MainContentGrid" ColumnDefinitions="260,Auto,*,Auto,310">

            <!-- LEFT: Card List Panel -->
            <DockPanel Grid.Column="0" Margin="4">
                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,4">
                    <TextBox x:Name="SearchBox"
                             Watermark="Search name, text, or ID..."
                             Text="{Binding SearchText}"
                             Margin="0,2"/>

                    <ComboBox
                              ItemsSource="{Binding NationOptions}"
                              SelectedItem="{Binding SelectedNationFilter}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="m:ClanDefinition">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="12" Height="12" CornerRadius="2"
                                            Background="{Binding DisplayColor, Converter={x:Static conv:ColorToBrushConverter.Instance}}"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox
                              ItemsSource="{Binding ClanOptions}"
                              SelectedItem="{Binding SelectedClanFilter}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="m:ClanDefinition">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="12" Height="12" CornerRadius="2"
                                            Background="{Binding DisplayColor, Converter={x:Static conv:ColorToBrushConverter.Instance}}"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox ItemsSource="{Binding GradeOptions}"
                              SelectedIndex="{Binding SelectedGradeFilter}"
                              HorizontalAlignment="Stretch"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <CheckBox Content="No Nation" IsChecked="{Binding FilterNoNation}"/>
                        <CheckBox Content="No Clan" IsChecked="{Binding FilterNoClan}"/>
                        <Button x:Name="ScrollToTopBtn" Content="&#x25B2;" FontSize="10"
                                Padding="4,1" MinWidth="0" MinHeight="0"
                                VerticalAlignment="Center" Click="OnScrollToTopClick"
                                ToolTip.Tip="Scroll to top"/>
                        <Button x:Name="ScrollToBottomBtn" Content="&#x25BC;" FontSize="10"
                                Padding="4,1" MinWidth="0" MinHeight="0"
                                VerticalAlignment="Center" Click="OnScrollToBottomClick"
                                ToolTip.Tip="Scroll to bottom"/>
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="CardListBox"
                         ItemsSource="{Binding FilteredCards}"
                         SelectedItem="{Binding SelectedCard}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:Card">
                            <DockPanel Margin="0,1">
                                <Border Width="4" DockPanel.Dock="Left" Margin="0,0,6,0" CornerRadius="2"
                                        Background="{Binding Converter={StaticResource CardColorConv}}"/>
                                <TextBlock>
                                    <Run Text="[" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <Run Text="{Binding CardStat}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <Run Text="] " FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <Run Text="{Binding CardName}"/>
                                </TextBlock>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"/>

            <!-- CENTER: Card Editor Panel -->
            <ScrollViewer Grid.Column="2" Margin="4"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4" IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="4" DataContext="{Binding SelectedCard}" x:DataType="m:Card" x:CompileBindings="False">

                    <!-- Core Properties -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Core Properties" FontWeight="Bold" FontSize="14"/>
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Card ID:" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <NumericUpDown x:Name="CardStatEditor" FormatString="0"
                                                   Value="{Binding CardStat}"
                                                   IsEnabled="{Binding IsCustomCard}"
                                                   Minimum="1" Maximum="31999" Width="160"
                                                   FontWeight="Bold"/>
                                    <TextBlock Text="(custom)" FontSize="11" Foreground="{DynamicResource AccentTealBrush}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsCustomCard}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CardName}" x:DataType="m:Card"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding EncodingIssueDetails}" Foreground="Red" FontSize="11"
                                           TextWrapping="Wrap" IsVisible="{Binding HasEncodingIssue}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Grade:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="3" Grid.Column="1" Value="{Binding UnitGrade}" Minimum="0" Width="120" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Power:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="4" Grid.Column="1" Value="{Binding PowerStat}" Minimum="0" Increment="1000" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Shield:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="5" Grid.Column="1" Value="{Binding DefensePowerStat}" Minimum="0" Increment="5000" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Nation:" VerticalAlignment="Center"/>
                                <ctrl:FactionPicker Grid.Row="6" Grid.Column="1" Value="{Binding DCards}" IsClanMode="False" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Clan:" VerticalAlignment="Center"/>
                                <ctrl:FactionPicker Grid.Row="7" Grid.Column="1" Value="{Binding CardInClan}" IsClanMode="True" HorizontalAlignment="Left"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        IsVisible="{Binding DataContext.DuplicateNameWarning,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding DataContext.DuplicateNameWarning,
                                               RelativeSource={RelativeSource AncestorType=Window}}"
                                           Foreground="{DynamicResource WarningOrangeBrush}" FontSize="11" TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <Button Content="Fix" FontSize="11" Padding="8,2"
                                        Command="{Binding DataContext.FixDuplicateNameCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card Text -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Card Text" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                <Button Content="Auto-preformat" FontSize="11" Padding="8,2"
                                        Click="OnAutoPreformatClick" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox Text="{Binding CardText}" AcceptsReturn="True"
                                     TextWrapping="Wrap" MinHeight="120" MaxHeight="300"/>
                        </StackPanel>
                    </Border>

                    <!-- Trigger -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Trigger" FontWeight="Bold" FontSize="14"/>
                            <ComboBox SelectedIndex="{Binding TriggerUnit}" Width="200" HorizontalAlignment="Left">
                                <ComboBoxItem Content="None" Tag="0"/>
                                <ComboBoxItem Content="Draw (1)"/>
                                <ComboBoxItem Content="Critical (2)"/>
                                <ComboBoxItem Content="Stand (3)"/>
                                <ComboBoxItem Content="Heal (4)"/>
                                <ComboBoxItem Content="Front (5)"/>
                                <ComboBoxItem Content="Over (6)"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Persona Ride -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Persona Ride" FontWeight="Bold" FontSize="14"/>
                            <WrapPanel>
                                <CheckBox Content="Persona Ride" IsChecked="{Binding PersonaRide}" Margin="0,0,12,0"/>
                                <CheckBox Content="Activated" IsChecked="{Binding PersonaRideAct}" Margin="0,0,12,0"/>
                                <CheckBox Content="Forbid Cross Upon" IsChecked="{Binding ForbidCrossPersonaRideUpon}"/>
                            </WrapPanel>
                            <Grid ColumnDefinitions="100,*">
                                <TextBlock Text="Cross Name:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding PersonaRideCardName}" Watermark="PersonaRideCardName"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Imaginary Gifts -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Imaginary Gifts" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="On Ride:" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                            <WrapPanel>
                                <CheckBox Content="Force" IsChecked="{Binding BlueTokenAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="Protect" IsChecked="{Binding GreenTokenAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="Accel" IsChecked="{Binding OrangeTokenAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="Both Force" IsChecked="{Binding BlueTokenBoth}"/>
                            </WrapPanel>
                            <TextBlock Text="Generators (Shift+Click):" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                            <WrapPanel>
                                <CheckBox Content="Force" IsChecked="{Binding ForceAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="Protect" IsChecked="{Binding ProtectAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="Accel" IsChecked="{Binding AccelAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="All Gifts" IsChecked="{Binding GiftAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="Select Gift" IsChecked="{Binding GiftAddSelect}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Token Generator -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Token Generator" FontWeight="Bold" FontSize="14"/>
                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Summoner ID:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="0" Grid.Column="1" Value="{Binding TokenSummoner}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Summoner 2:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="1" Grid.Column="1" Value="{Binding TokenSummoner2}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Summoner 3:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="2" Grid.Column="1" Value="{Binding TokenSummoner3}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Position:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TokenSummonerPosition}" Watermark="V/R/VR/SHIFT/RodeUpon" Width="200" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Quantity:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="4" Grid.Column="1" Value="{Binding TokenSummonerQuantity}" Minimum="1" Maximum="2" Width="120" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="RodeUpon #:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="5" Grid.Column="1" Value="{Binding TokenSummonerRodeUponNumber}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Choice Text:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding TokenSummoner2Text}" Watermark="Prompt question"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Button 1:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding TokenSummoner2Button1}" Width="200" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Button 2:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding TokenSummoner2Button2}" Width="200" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Text="Button 3:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding TokenSummoner2Button3}" Width="200" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Search Effect -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Search Effect" FontWeight="Bold" FontSize="14"/>
                            <CheckBox Content="Enable Search Effect" IsChecked="{Binding SearchEffect}"/>
                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4"
                                  IsVisible="{Binding SearchEffect}">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Position:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SearchEffectPosition}" Watermark="V/R/VR/SHIFT" Width="150" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Look At #:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="1" Grid.Column="1" Value="{Binding SearchEffectLookAtQuantity}" Width="100" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mode:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SearchEffectMode}" Watermark="Card/Clan/NoClan/CheckGrade/..." Width="250" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Argument 1:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SearchEffectArgument1}" Width="200" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Argument 2:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SearchEffectArgument2}" Width="200" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Argument 3:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SearchEffectArgument3}" Width="200" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Found Action:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ActivateSearchFoundAction}" Watermark="AddToHand/V/SendToTopCard[UpTo]" Width="250" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Rest Action:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ActivateSearchRestAction}" Watermark="Shu/SelectBot/ShuffleBotDeck" Width="250" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Arms -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Arms" FontWeight="Bold" FontSize="14"/>
                            <WrapPanel>
                                <CheckBox Content="Arms" IsChecked="{Binding Arms}" Margin="0,0,12,0"/>
                                <CheckBox Content="Left Arms" IsChecked="{Binding LeftArms}" Margin="0,0,12,0"/>
                                <CheckBox Content="Right Arms" IsChecked="{Binding RightArms}" Margin="0,0,12,0"/>
                                <CheckBox Content="Arms As Unit" IsChecked="{Binding ArmsAsUnit}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Legality & Visibility -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Legality &amp; Visibility" FontWeight="Bold" FontSize="14"/>
                            <WrapPanel>
                                <CheckBox Content="Restricted" IsChecked="{Binding CardLimidet}" Margin="0,0,12,0"/>
                                <CheckBox Content="Banned" IsChecked="{Binding CardBanned}" Margin="0,0,12,0"/>
                                <CheckBox Content="Premium Only" IsChecked="{Binding OldCardStat}" Margin="0,0,12,0"/>
                                <CheckBox Content="Premium 10k Trigger" IsChecked="{Binding NewTriggerStat}" Margin="0,0,12,0"/>
                                <CheckBox Content="Hide in Editor" IsChecked="{Binding DontShowInDeckEditor}"/>
                            </WrapPanel>
                            <Grid ColumnDefinitions="100,*">
                                <TextBlock Text="Max Copies:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Column="1" Value="{Binding CardCopies}" Minimum="0" Maximum="99" Width="120" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Special Mechanics -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Special Mechanics" FontWeight="Bold" FontSize="14"/>
                            <WrapPanel>
                                <CheckBox Content="G-Zone" IsChecked="{Binding ExtraDeck}" Margin="0,0,12,0"/>
                                <CheckBox Content="Quick Shield" IsChecked="{Binding QuickShieldAdd}" Margin="0,0,12,0"/>
                                <CheckBox Content="Remove From Drop" IsChecked="{Binding RemoveFromDrop}" Margin="0,0,12,0"/>
                                <CheckBox Content="Regalis Piece" IsChecked="{Binding RegalisPiece}" Margin="0,0,12,0"/>
                                <CheckBox Content="Astral Plane" IsChecked="{Binding Uranus}" Margin="0,0,12,0"/>
                                <CheckBox Content="Treasure Markers" IsChecked="{Binding MimicNotEvil}" Margin="0,0,12,0"/>
                                <CheckBox Content="Counters" IsChecked="{Binding UseCounters}" Margin="0,0,12,0"/>
                                <CheckBox Content="Ult. Stride Remove" IsChecked="{Binding DeleteAllExtraInEndPhase}" Margin="0,0,12,0"/>
                                <CheckBox Content="Extended TextBox" IsChecked="{Binding ExtendedTextBox}" Margin="0,0,12,0"/>
                                <CheckBox Content="Token In Hand" IsChecked="{Binding TokenInHand}" Margin="0,0,12,0"/>
                                <CheckBox Content="Can Attack Back Row" IsChecked="{Binding CanAttackFromBackRow}" Margin="0,0,12,0"/>
                                <CheckBox Content="Enable Back Row Attack" IsChecked="{Binding EnableAttackFromBackRow}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Advanced -->
                    <Border Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Advanced" FontWeight="Bold" FontSize="14"/>
                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nation 2:" VerticalAlignment="Center"/>
                                <ctrl:FactionPicker Grid.Row="0" Grid.Column="1" Value="{Binding DCards2}" IsClanMode="False" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Clan 2-9:" VerticalAlignment="Center"/>
                                <WrapPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <ctrl:FactionPicker Value="{Binding CardInClan2}" IsClanMode="True" Margin="0,0,4,4"/>
                                    <ctrl:FactionPicker Value="{Binding CardInClan3}" IsClanMode="True" Margin="0,0,4,4"/>
                                    <ctrl:FactionPicker Value="{Binding CardInClan4}" IsClanMode="True" Margin="0,0,4,4"/>
                                </WrapPanel>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Another Side:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="2" Grid.Column="1" Value="{Binding AnotherSide}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Reassigned ID:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="3" Grid.Column="1" Value="{Binding CardReassignedId}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="V Attack Buff:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="4" Grid.Column="1" Value="{Binding AttackFromVBuff}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="R Attack Buff:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="5" Grid.Column="1" Value="{Binding AttackFromRBuff}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="VR Attack Buff:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="6" Grid.Column="1" Value="{Binding AttackFromVRBuff}" Width="160" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Required Van:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding RequiredVan}" Width="250" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Move All:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding MoveAll}" Watermark="Bind/Hand/Drop/OriginalDress" Width="220" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Text="Reveal Top X:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="9" Grid.Column="1" Value="{Binding RevealTopX}" Width="120" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Buddy World:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="10" Grid.Column="1" Value="{Binding BuddyWorld}" Width="120" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="11" Grid.Column="0" Text="Gauge Charge:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="11" Grid.Column="1" Value="{Binding GaugeCharge}" Width="120" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="12" Grid.Column="0" Text="Deck Grade +/-:" VerticalAlignment="Center"/>
                                <NumericUpDown FormatString="0" Grid.Row="12" Grid.Column="1" Value="{Binding UnitGradeIncrementInDeck}" Width="120" HorizontalAlignment="Left"/>
                            </Grid>
                            <WrapPanel Margin="0,4,0,0">
                                <CheckBox Content="Reveal (Starhulk)" IsChecked="{Binding Reveal}" Margin="0,0,12,0"/>
                                <CheckBox Content="Scene Effect (Harri)" IsChecked="{Binding SceneEffect}" Margin="0,0,12,0"/>
                                <CheckBox Content="Coco Add" IsChecked="{Binding CocoAdd}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Source Info -->
                    <Border Background="{DynamicResource SourceInfoBackgroundBrush}" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding SourceFile, StringFormat='File: {0}'}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"/>
                            <TextBlock Text="{Binding SourceLineStart, StringFormat='Lines: {0}'}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="3" Width="4" ResizeDirection="Columns"/>

            <!-- RIGHT: Preview Panel -->
            <Grid x:Name="PreviewGrid" Grid.Column="4" Margin="4" RowDefinitions="440,4,*">
                <!-- Card Image + Actions -->
                <DockPanel Grid.Row="0" MinHeight="100">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                        <Button Content="Replace Image"
                                Click="OnReplaceImageClick"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <Border Background="#333" CornerRadius="4">
                        <Image Source="{Binding CardImagePath, Converter={StaticResource PathToBitmap}}"
                               Stretch="Uniform"
                               StretchDirection="DownOnly"/>
                    </Border>
                </DockPanel>

                <GridSplitter Grid.Row="1" Height="4" ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"/>

                <!-- In-Game Text Preview -->
                <Border Grid.Row="2" Background="{DynamicResource SectionBackgroundBrush}" CornerRadius="4" BorderBrush="{DynamicResource SectionBorderBrush}" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="In-Game Text Preview (Reference-Only!)"
                                   FontWeight="Bold" FontSize="12" Margin="8,4,8,2"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ctrl:CardTextPreviewControl
                                x:Name="CardTextPreview"
                                CardText="{Binding ((vm:MainWindowViewModel)DataContext).SelectedCard.CardText, RelativeSource={RelativeSource AncestorType=Window}}"
                                CardName="{Binding ((vm:MainWindowViewModel)DataContext).SelectedCard.CardName, RelativeSource={RelativeSource AncestorType=Window}}"
                                ExtendedTextBox="{Binding ((vm:MainWindowViewModel)DataContext).SelectedCard.ExtendedTextBox, RelativeSource={RelativeSource AncestorType=Window}}"
                                x:DataType="ctrl:CardTextPreviewControl"
                                MinHeight="430"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

        </Grid>
    </DockPanel>
</Window>
